# Parley connection
PARLEY_BASE_URL=https://parley.example.com

# Auth — use ONE of these options:
# Option A: paste your JWT from the browser (DevTools → Application → localStorage → token)
PARLEY_TOKEN=eyJ...

# Option B: login credentials (token is fetched automatically)
# PARLEY_EMAIL=you@example.com
# PARLEY_PASSWORD=yourpassword

# Ollama cloud
OLLAMA_URL=https://ollama.com
OLLAMA_KEY=your-ollama-api-key
OLLAMA_MODEL=qwen3.5:cloud

# Safety switch — set to "true" to actually send replies
# Leave as "false" to run in observation mode (logs what it would say, sends nothing)
SELFBOT_ENABLED=false

# Optional: short message prepended when someone first @mentions you (leave blank to skip)
# SELFBOT_AWAY_MSG=Hey! I'm currently away — my assistant will help.

# Logging level: DEBUG, INFO, WARNING
SELFBOT_LOG_LEVEL=INFO
