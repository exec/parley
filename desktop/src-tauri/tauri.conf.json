{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parley",
  "version": "0.5.3",
  "identifier": "app.parley.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Parley",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Parley desktop client",
    "longDescription": "Parley desktop client.",
    "resources": ["Credits.rtf"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "iOS": {
      "developmentTeam": "7Q9P3WCY2D"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["parley"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/exec/parley/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2Rjg2OTI0RDU5QUQyOTUKUldTVjBwclZKR240aHQrMkVVNkhTU3lCb3BUVXdMeFZzaU1YaFZSTlYvZ2EyQVdyMUI4TUpHS0sK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
