# Terraform
terraform/*.tfvars
terraform/.terraform/
# F-gitignore-gap: catch the live state, the .backup rotation Terraform writes
# on every apply, AND timestamped rotations like terraform.tfstate.<unix>.backup.
# The previous literal patterns let timestamped backups slip through and be
# committed by accident (two such files had to be purged).
terraform/**/terraform.tfstate*

# Go binaries
/api
/parley-api
/parley-admin
/admin
/bin/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Frontend
frontend/node_modules/
frontend/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets / env files
frontend/.env
.env
**/.env
**/.env.local
.worktrees/

# Local deployment docs (contain IPs / setup notes)
DEPLOYMENT.md

# Proxmox terraform state and secrets
terraform/proxmox/*.tfvars
terraform/proxmox/.terraform/
# terraform.tfstate{,.*} here is covered by the terraform/**/terraform.tfstate*
# pattern above; kept explicit in neighbouring comment for grep-ability.
bench/parley-bench

# Build artifacts / state that should never be committed
/parley-bin
/terraform.tfstate
docs/node_modules/
docs/.vitepress/dist/
extras/parley/**/__pycache__/
extras/parley/**/*.pyc
extras/parley/**/*.egg-info/

# Claude Code session lock file
.claude/scheduled_tasks.lock
